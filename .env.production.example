# =============================================================================
# AFAQ PLATFORM — PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy to your hosting provider's secret manager / env panel.
# NEVER commit real values. All data must reside in KSA for PDPL compliance.
# =============================================================================

# ─── FRONTEND (Vercel / similar) ───────────────────────────────────────────────

# Backend API base URL (no trailing slash) — used by the Next.js frontend
NEXT_PUBLIC_API_URL=https://api.yourdomain.sa/api/v1

# Supabase (browser-safe — from Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: Gemini for future client-side AI features
# GEMINI_API_KEY=

# ─── BACKEND API (Railway / Render / AWS ECS) ────────────────────────────────

NODE_ENV=production
PORT=4000
DATA_RESIDENCY=KSA

# PostgreSQL connection string (Supabase / Neon / AWS RDS me-south-1)
# Must use SSL in production: ?sslmode=require
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Supabase admin (server-only — never expose to frontend)
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT secrets — generate with: openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Comma-separated allowed frontend origins (your live domain)
CORS_ORIGINS=https://yourdomain.sa,https://www.yourdomain.sa

# ─── OTP / SMS (Unifonic or local KSA gateway) ───────────────────────────────

OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
SMS_PROVIDER=unifonic
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=AFAQ

# ─── AI ORCHESTRATOR ─────────────────────────────────────────────────────────

GEMINI_API_KEY=

# ─── OAUTH (Google / Apple Sign-In) ──────────────────────────────────────────

GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=

# ─── NAFATH (KSA National ID) ──────────────────────────────────────────────────

NAFATH_API_URL=
NAFATH_API_KEY=
NAFATH_CALLBACK_URL=https://api.yourdomain.sa/api/v1/auth/nafath/callback

# ─── ZATCA E-INVOICING (Phase 2) ─────────────────────────────────────────────

ZATCA_ENV=production
ZATCA_CSID=
ZATCA_SECRET=
ZATCA_PRIVATE_KEY=

# ─── MONITORING (optional) ───────────────────────────────────────────────────

# SENTRY_DSN=
# LOG_LEVEL=info
